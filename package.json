{
  "name": "@valeryan15/virtual-scroll",
  "version": "0.1.2",
  "description": "Virtual scroll React component library",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valeryan15/virtual-scroll.git"
  },
  "bugs": {
    "url": "https://github.com/valeryan15/virtual-scroll/issues"
  },
  "homepage": "https://github.com/valeryan15/virtual-scroll#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/virtual-scroll.cjs",
  "module": "dist/virtual-scroll.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/virtual-scroll.mjs",
      "require": "./dist/virtual-scroll.cjs"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": "22.21.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "prepack": "yarn build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tslint -p tsconfig.json -c tslint.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@chromatic-com/storybook": "^5.0.0",
    "@storybook/addon-a11y": "^10.2.3",
    "@storybook/addon-docs": "^10.2.3",
    "@storybook/addon-vitest": "^10.2.3",
    "@storybook/react-vite": "^10.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "playwright": "^1.58.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.3",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
